+    'PREFLIGHT': {'badge': 'bg-gray-500/10 text-gray-300 border-gray-500/30'},
+    'CODING':    {'badge': 'bg-accent/10 text-accent border-accent/30'},
+    'WATCH':     {'badge': 'bg-warn/10 text-warn border-warn/30'},
+    'FIX':       {'badge': 'bg-warn/10 text-warn border-warn/30'},
+    'MERGE':     {'badge': 'bg-ok/10 text-ok border-ok/30'},
