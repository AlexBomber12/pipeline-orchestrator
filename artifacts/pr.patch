+-def test_commit_and_push_dirty_gives_ci_script_generous_timeout(
+-    monkeypatch: pytest.MonkeyPatch,
+-) -> None:
+-    """Codex P2 (round 3): ``scripts/ci.sh`` runs the user repo's full
