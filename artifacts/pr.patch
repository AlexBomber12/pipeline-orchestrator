-++++++++++--            entry
-++++++++++--            for entry in history
-++++++++++--            if str(entry.get("state", "")) in _EVENT_ERROR_STATES
-++++++++++--        ]
-++++++++++--    if filter_name == "state":
-++++++++++--        filtered: list[dict[str, Any]] = []
-++++++++++--        previous: str | None = None
-++++++++++--        for entry in history:
-++++++++++--            current = str(entry.get("state", ""))
-++++++++++--            if current != previous:
-++++++++++--                filtered.append(entry)
-++++++++++--                previous = current
