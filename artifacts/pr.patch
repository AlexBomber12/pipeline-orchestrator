+-+++def _build_node_options() -> str:
+-+++    memory_flag = "--max-old-space-size=4096"
+-+++    existing = os.environ.get("NODE_OPTIONS", "").strip()
+-+++    return f"{existing} {memory_flag}".strip() if existing else memory_flag
