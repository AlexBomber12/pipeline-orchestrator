+-+++++++++-+-    assert 'hx-trigger="every 5s"' in body
+-+++++++++-+-    # the active filter round-trips through hx-vals so the next poll
+-+++++++++-+-    # continues to request the filtered view instead of resetting
+-+++++++++-+-    assert 'hx-vals=\'{"filter": "errors"}\'' in body
