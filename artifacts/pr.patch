++++--+-++async def run_claude_async(
++++--+-++    prompt: str,
++++--+-++    cwd: str,
++++--+-++    timeout: int = 600,
++++--+-++    model: str | None = None,
++++--+-++) -> tuple[int, str, str]:
++++--+-++    cmd = [
++++--+-++        "claude",
++++--+-++        "--print",
++++--+-++        "--dangerously-skip-permissions",
++++--+-++        "--bare",
++++--+-++        "--no-session-persistence",
++++--+-++    ]
