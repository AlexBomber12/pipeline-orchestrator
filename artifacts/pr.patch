+++-+++        if "HTTP 404" not in str(exc):
+++-+++            raise
+++-+++        return ""
+++-+++    if not reviews:
+++-+++        return ""
+++-+++    for review in reversed(reviews):
+++-+++        user = (review.get("user") or {}).get("login", "") or ""
+++-+++        if "codex" not in user.lower():
+++-+++            continue
+++-+++        sha = review.get("commit_id") or ""
+++-+++        if sha:
+++-+++            return sha
+++-+++    return ""
